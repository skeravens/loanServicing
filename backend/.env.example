NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=loan_platform
DB_SSL=false

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# Cognito
COGNITO_USER_POOL_ID=us-east-1_EXAMPLE
COGNITO_CLIENT_ID=example_client_id
COGNITO_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_EXAMPLE/.well-known/jwks.json

# KMS
KMS_KEY_ID=alias/loan-platform-pii

# S3
S3_EXPORTS_BUCKET=loan-platform-exports

# CORS
ALLOWED_ORIGINS=http://localhost:3001
